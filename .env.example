# Backend API base URL.
#  - iOS simulator:                http://localhost:3000
#  - Android emulator:             http://10.0.2.2:3000
#  - Real device (any OS):         http://<your-mac-LAN-IP>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
GOOGLE_MAPS_ANDROID_KEY=

# Sentry crash reporting. Leave blank to disable — the app no-ops without it.
EXPO_PUBLIC_SENTRY_DSN=

# Skip Sentry source-map upload during native builds. Keep true until
# SENTRY_ORG, SENTRY_PROJECT and SENTRY_AUTH_TOKEN are configured (those
# are what give you symbolicated production stack traces).
SENTRY_DISABLE_AUTO_UPLOAD=true